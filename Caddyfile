{
    # Global options
    email admin@sovi-dz.com

    # Enable on-demand TLS
    on_demand_tls {
        ask http://backend:8000/api/stores/check-domain/
        interval 2m
        burst 5
    }
}

# Handle all HTTP traffic (redirect to HTTPS)
http:// {
    redir https://{host}{uri}
}

# Handle all HTTPS traffic
https:// {
    tls {
        on_demand
    }

    # API routes go to backend
    reverse_proxy /api/* http://backend:8000
    reverse_proxy /admin/* http://backend:8000
    reverse_proxy /static/django/* http://backend:8000
    reverse_proxy /media/* http://backend:8000

    # All other routes go to Next.js frontend
    reverse_proxy http://frontend:3000
}
