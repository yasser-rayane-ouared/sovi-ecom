        { id: 'pending-info', section_type: 'product_info', config: {}, order: 1 },
        { id: 'pending-checkout', section_type: 'checkout', config: {}, order: 2 },
        { id: 'pending-footer', section_type: 'footer', config: { content: "© جميع الحقوق محفوظة", background_color: "#ffffff", color: "#666666", text_align: "center", font_size: "14px" }, order: 3 }
